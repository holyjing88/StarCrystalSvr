{
  "schema": 1,
  "target": "linux-x86_64",
  "notes": "大文件不入 Git；在联网机执行 fetch-linux-offline-packages.sh 填充各子目录后，整包拷贝到离线机再执行 install-linux-offline.sh。",
  "packages": {
    "mysql": {
      "version": "8.4.8",
      "subdir": "mysql",
      "expectedFiles": [
        "mysql-8.4.8-linux-glibc2.28-x86_64.tar.xz"
      ],
      "installDirHint": "<games-root>/mysql-portable-linux/mysql-8.4.8-linux-glibc2.28-x86_64",
      "url": "https://dev.mysql.com/get/Downloads/MySQL-8.4/mysql-8.4.8-linux-glibc2.28-x86_64.tar.xz"
    },
    "redis": {
      "version": "7.2.6",
      "subdir": "redis",
      "expectedFiles": [
        "redis-7.2.6.tar.gz"
      ],
      "buildInstallDir": "../../../../redis/linux",
      "url": "https://download.redis.io/releases/redis-7.2.6.tar.gz"
    },
    "go": {
      "version": "1.24.0",
      "subdir": "go",
      "expectedFiles": [
        "go1.24.0.linux-amd64.tar.gz"
      ],
      "url": "https://go.dev/dl/go1.24.0.linux-amd64.tar.gz"
    },
    "goModules": {
      "subdir": "go-modules",
      "expectedFiles": [
        "gomod-cache.tar.gz"
      ],
      "description": "go mod download 缓存，供离线 go build"
    },
    "runtime": {
      "subdir": "runtime/deb",
      "description": "MySQL/编译 Redis 常用系统库 .deb（Ubuntu/Debian，可选）",
      "debPackages": [
        "libaio1",
        "libncurses6",
        "libtinfo6",
        "numactl"
      ],
      "buildPackagesNote": "编译 Redis 还需 gcc、make；联网机 fetch 会尝试 apt-get download build-essential 元包依赖"
    }
  }
}
