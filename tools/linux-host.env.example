# StarCrystal Linux 宿主机连接信息（复制为 linux-host.local.env 后填写，勿提交版本库）
#
#   cp tools/linux-host.env.example tools/linux-host.local.env
#
LINUX_HOST=192.168.75.99
LINUX_USER=root
LINUX_PASSWORD=your-password-here
LINUX_REPO=/home/holyjing/starcrystalsvr

# Docker 脚本目录；宿主机 MySQL 已占 3306 时用备用端口
LINUX_DOCKER_DIR=/home/holyjing/starcrystalsvr/tools/docker
DOCKER_MYSQL_PORT=13306
DOCKER_REDIS_PORT=16379
# MySQL root（宿主 3306 / Docker 13306 脚本默认）
MYSQL_ROOT_PASSWORD=jgyjgyjgy
DOCKER_MYSQL_ROOT_PASSWORD=jgyjgyjgy
# MySQL 宿主路径（tools/scripts/mysql 启停/备份脚本默认）
MYSQL_DATA_DIR=/app/mysql/db
MYSQL_BACKUP_DIR=/app/mysql/db_backup
# Redis 宿主路径（tools/scripts/redis 启停脚本默认）
REDIS_DATA_DIR=/app/redis/db
REDIS_BACKUP_DIR=/app/redis/db_backup
# 宿主数据目录（与 docker_mysql.sh / docker_redis.sh 默认一致）
DOCKER_MYSQL_DATA=/app/mysql/db
DOCKER_MYSQL_BACKUP_DIR=/app/mysql/db_backup
DOCKER_REDIS_DATA=/app/redis/db
DOCKER_REDIS_BACKUP_DIR=/app/redis/db_backup
DOCKER_RELEASE_SVR_DIR=/app/starcrystalsvr

# 版本库：仅在 Windows 执行 svn update / commit（Y:\holyjing\starcrystalsvr）
# Linux 通过 SMB 共享同一目录，勿在 Linux 安装 subversion（见 tools/scripts/linux-uninstall-svn.sh）
